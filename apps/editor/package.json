{
  "name": "tagma-editor",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "ensure:opencode": "bun ../electron/scripts/fetch-opencode.mjs",
    "dev:server": "bun run ensure:opencode && bun run dev:server:watch",
    "dev:server:watch": "bun --watch server/index.ts",
    "dev:client": "vite",
    "dev:client:desktop": "vite --host 127.0.0.1 --strictPort",
    "build": "vite build",
    "build:sidecar": "bun scripts/build-desktop-sidecar.ts",
    "start": "bun server/index.ts",
    "preview": "vite preview",
    "test": "bun scripts/test-serial.mjs",
    "check:server": "tsc -p tsconfig.server.json --noEmit",
    "install:clean": "rimraf node_modules bun.lock && bun pm cache rm && bun install"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.15.13",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.15.2",
    "@tagma/sdk": "workspace:*",
    "@tagma/types": "workspace:*",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "express": "^5.1.0",
    "framer-motion": "^12.40.0",
    "grammy": "^1.42.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tar": "^7.5.13",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@types/tar": "^7.0.87",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.1"
  }
}
