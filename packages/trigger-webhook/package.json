{
  "name": "@tagma/trigger-webhook",
  "version": "0.1.4",
  "description": "HTTP webhook trigger plugin for tagma-sdk pipelines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoTagma/tagma-mono.git",
    "directory": "packages/trigger-webhook"
  },
  "bugs": "https://github.com/GoTagma/tagma-mono/issues",
  "homepage": "https://github.com/GoTagma/tagma-mono/tree/main/packages/trigger-webhook#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "tagma-plugin",
    "tagma",
    "trigger",
    "webhook",
    "http"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "tagmaPlugin": {
    "category": "triggers",
    "type": "webhook"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@tagma/types": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  }
}
