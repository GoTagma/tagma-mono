{
  "name": "@tagma/types",
  "version": "0.4.6",
  "description": "Shared type surface for the Tagma engine and plugins — types only, no runtime code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoTagma/tagma-mono.git",
    "directory": "packages/types"
  },
  "bugs": "https://github.com/GoTagma/tagma-mono/issues",
  "homepage": "https://github.com/GoTagma/tagma-mono/tree/main/packages/types#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "bun run build"
  }
}
