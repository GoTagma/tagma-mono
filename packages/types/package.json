{
  "name": "@tagma/types",
  "version": "0.2.0",
  "description": "Shared type surface for the Tagma engine and plugins — types only, no runtime code",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}