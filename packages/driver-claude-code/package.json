    "directory": "packages/driver-claude-code"
  },
  "bugs": "https://github.com/GoTagma/tagma-mono/issues",
  "homepage": "https://github.com/GoTagma/tagma-mono/tree/main/packages/driver-claude-code#readme",
  "type": "module",
  "main": "./dist/index.js",
