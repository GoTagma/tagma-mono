{
  "name": "tagma-desktop",
  "private": true,
  "version": "0.1.16",
  "description": "Electron desktop shell for Tagma Editor",
  "author": {
    "name": "Tagma",
    "email": "danuberiverferryman@gmail.com"
  },
  "homepage": "https://github.com/GoTagma/tagma-mono",
  "main": "dist/main.js",
  "tagma": {
    "bundledOpencodeVersion": "1.4.4",
    "channel": "stable",
    "updateManifestBaseUrl": "https://tagma-web.danuberiverferryman.workers.dev/editor-updates"
  },
  "scripts": {
    "build": "tsc",
    "build:deps": "cd ../editor && bun run build && bun run build:sidecar",
    "build:all": "bun run build:deps && bun run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "dev": "bun run build && electron .",
    "start": "electron .",
    "fetch:opencode": "bun ./scripts/fetch-opencode.mjs",
    "pack": "bun run build:all && bun run fetch:opencode && electron-builder --dir",
    "dist:win": "bun run build:all && bun ./scripts/fetch-opencode.mjs --platform=win32 --arch=x64 && electron-builder --win",
    "dist:linux": "bun run build:all && bun ./scripts/fetch-opencode.mjs --platform=linux --arch=x64 && electron-builder --linux",
    "dist:mac": "bun run build:all && bun ./scripts/fetch-opencode.mjs --platform=darwin --arch=arm64 && bun ./scripts/fetch-opencode.mjs --platform=darwin --arch=x64 && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.2.0",
    "electron-builder": "^25.1.8",
    "tar": "^7.5.13",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.tagma.editor",
    "productName": "Tagma",
    "artifactName": "Tagma-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**"
    ],
    "extraResources": [
      {
        "from": "../editor/dist",
        "to": "editor-dist",
        "filter": ["**/*"]
      },
      {
        "from": "../editor/desktop-dist",
        "to": "editor-sidecar",
        "filter": ["**/*"]
      },
      {
        "from": "build/opencode/${platform}-${arch}",
        "to": "opencode",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "tar.gz"],
      "icon": "build/icon.png",
      "category": "Development",
      "maintainer": "Tagma <danuberiverferryman@gmail.com>"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    }
  }
}
