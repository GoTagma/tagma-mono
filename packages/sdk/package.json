{
  "name": "@tagma/sdk",
  "version": "0.4.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoTagma/tagma-sdk.git"
  },
  "type": "module",
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.7",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "release": "bun scripts/release.ts",
    "release:publish": "bun scripts/release.ts --publish"
  },
  "dependencies": {
    "@tagma/types": "workspace:*",
    "js-yaml": "^4.1.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  }
}