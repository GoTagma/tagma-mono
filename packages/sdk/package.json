{
  "name": "@tagma/sdk",
  "version": "0.6.11",
  "description": "Local AI task orchestration engine — core SDK for tagma pipelines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoTagma/tagma-mono.git",
    "directory": "packages/sdk"
  },
  "bugs": "https://github.com/GoTagma/tagma-mono/issues",
  "homepage": "https://github.com/GoTagma/tagma-mono/tree/main/packages/sdk#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js",
      "default": "./dist/sdk.js"
    },
    "./ports": {
      "types": "./dist/ports.d.ts",
      "import": "./dist/ports.js",
      "default": "./dist/ports.js"
    }
  },
  "files": [
    "dist",
    "src",
    "scripts/preinstall.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "release": "bun scripts/release.ts",
    "release:publish": "bun scripts/release.ts --publish"
  },
  "dependencies": {
    "@tagma/types": "workspace:*",
    "js-yaml": "^4.1.0",
    "chokidar": "^4.0.0"
  }
}
