{
  "name": "@tagma/sdk",
  "version": "0.7.17",
  "description": "Local AI task orchestration SDK for Tagma pipelines",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoTagma/tagma-mono.git",
    "directory": "packages/sdk"
  },
  "bugs": "https://github.com/GoTagma/tagma-mono/issues",
  "homepage": "https://github.com/GoTagma/tagma-mono/tree/main/packages/sdk#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./yaml": {
      "types": "./dist/yaml.d.ts",
      "import": "./dist/yaml.js",
      "default": "./dist/yaml.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "default": "./dist/plugins.js"
    },
    "./pipeline-runner": {
      "types": "./dist/pipeline-runner.d.ts",
      "import": "./dist/pipeline-runner.js",
      "default": "./dist/pipeline-runner.js"
    },
    "./approval": {
      "types": "./dist/approval.d.ts",
      "import": "./dist/approval.js",
      "default": "./dist/approval.js"
    },
    "./utils": {
      "types": "./dist/utils-api.d.ts",
      "import": "./dist/utils-api.js",
      "default": "./dist/utils-api.js"
    },
    "./dataflow": {
      "types": "./dist/dataflow.d.ts",
      "import": "./dist/dataflow.js",
      "default": "./dist/dataflow.js"
    }
  },
  "files": [
    "dist",
    "scripts/preinstall.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "build": "node ../../scripts/build-package.mjs",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "dependencies": {
    "@tagma/core": "workspace:*",
    "@tagma/runtime-bun": "workspace:*",
    "@tagma/types": "workspace:*",
    "js-yaml": "^4.1.0"
  }
}
